# GEMINI_API_KEY: Required for AI briefing generation (Gemini API)
GEMINI_API_KEY=""

# EDGE_CONFIG: Vercel Edge Config connection string (contains the ecfg_xxx ID)
# Format: https://edge-config.vercel.com/ecfg_xxx?token=yyy
EDGE_CONFIG=""

# VERCEL_API_TOKEN: Vercel personal access token for Edge Config Management API
# Required for all tag/category read-write operations
VERCEL_API_TOKEN=""

# NAVER_CLIENT_ID / NAVER_CLIENT_SECRET: Naver Open API credentials
# Register at https://developers.naver.com → 뉴스 검색 API
# Optional — if absent, only Google News RSS is collected.
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# VITE_KAKAO_JS_KEY: Kakao Developers JavaScript Key (for Kakao share)
VITE_KAKAO_JS_KEY=""

# DISABLE_HMR: Set to "true" to disable Vite HMR (used in restricted environments)
# DISABLE_HMR=true
